# LifeSe Backend — Environment Configuration
# Copy this file to .env and fill in the real values.
# ⚠️ NEVER commit .env to source control.

# ─── Core ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── Authentication ─────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=CHANGE_ME_another_random_64_char_string

# ─── Database ───────────────────────────────────────────────────
# For production: postgresql://USER:PASSWORD@HOST:5432/lifese
# For development: the JSON flat file is auto-used if DATABASE_URL is not set
DATABASE_URL=

# ─── SMS Provider ───────────────────────────────────────────────
# Options: fast2sms (default) | msg91
SMS_PROVIDER=fast2sms
SMS_API_KEY=YOUR_FAST2SMS_OR_MSG91_API_KEY_HERE
SMS_SENDER_ID=LFHSID

# ─── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
EMAIL_FROM=LifeSe <noreply@lifese.health>

# ─── ABDM (Ayushman Bharat Digital Mission) ──────────────────────
# Get sandbox credentials from: https://sandbox.abdm.gov.in/
ABDM_BASE_URL=https://dev.abdm.gov.in/gateway
ABDM_CLIENT_ID=YOUR_ABDM_CLIENT_ID
ABDM_CLIENT_SECRET=YOUR_ABDM_CLIENT_SECRET

# ─── Error Monitoring ───────────────────────────────────────────
SENTRY_DSN=YOUR_SENTRY_DSN_FROM_sentry_io

# ─── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
